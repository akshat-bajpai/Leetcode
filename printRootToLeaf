/*

Definition for Binary Tree Node
struct Node
{
    int data;
    struct Node* left;
    struct Node* right;

    Node(int x){
        data = x;
        left = right = NULL;
    }
};
*/

class Solution {
  public:
    void fill(Node* root, vector<vector<int>>& ans, vector<int>& temp){
        
        if (root==NULL) return;
        temp.push_back(root->data);
        if (root->left==NULL && root->right==NULL){
            ans.push_back(temp);
            temp.pop_back();
            return;
        }
        fill(root->left,ans,temp);
        fill(root->right,ans,temp);
        temp.pop_back();
    }
    vector<vector<int>> Paths(Node* root) {
        // code here
        vector<vector<int>> ans;
        vector<int> temp;
        if (root==NULL) return ans;
        fill(root,ans,temp);
        return ans;
    }
};
