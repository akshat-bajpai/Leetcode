#include <bits/stdc++.h>
using namespace std;

class Solution{
  private:
    void dfs(vector<int> adj[], vector<int>& vis, vector<int>& ans, int node){
        vis[node]=1;
        ans.push_back(node);
        for (auto it: adj[node]){
            if (vis[it]==0){
                dfs(adj,vis,ans,it);
            }
        }
    }

  public:
    vector<int> dfsOnGraph(int V, vector<int> adj[]){
        vector<int> vis(V,0);
        vector<int> ans;
        for (int i=0;i<V;i++){
            if (vis[i]==0){
                dfs(adj,vis,ans,i);
            }
        }
        return ans;
    }
};
